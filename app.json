{
  "expo": {
    "name": "Sophia",
    "slug": "mwbp-sophia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mwbp.sophia"
    },
    "android": {
      "package": "com.mwbp.sophia",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "sophia",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": false
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0FF"
    }
  }
}