{
  "expo": {
    "name": "Sophia",
    "slug": "mwbp-sophia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mwbp.sophia"
    },
    "android": {
      "package": "com.mwbp.sophia",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C3AED",
          "sounds": []
        }
      ]
    ],
    "scheme": "sophia",
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": false
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0FF"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1918ddd2-4fbf-481f-a040-f22186ba5cf8"
      }
    },
    "owner": "ground-link"
  }
}