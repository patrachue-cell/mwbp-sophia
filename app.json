{
  "expo": {
    "name": "Sophia",
    "slug": "mwbp-sophia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mwbp.sophia"
    },
    "android": {
      "package": "com.mwbp.sophia",
      "adaptiveIcon": {
        "backgroundColor": "#1a0a2e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "sophia",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": false
    }
  }
}
