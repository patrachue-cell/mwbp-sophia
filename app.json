{
  "expo": {
    "name": "Sophia",
    "slug": "mwbp-sophia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mwbp.sophia"
    },
    "android": {
      "package": "com.mwbp.sophia"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "sophia",
    "experiments": {
      "typedRoutes": false
    }
  }
}
